# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit secrets.

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather
TELEGRAM_BOT_TOKEN=12345:ABC...

# The chat ID where the bot sends previews (your personal chat or a group)
# The channel ID where approved applications are archived (private channel)
TELEGRAM_CHAT_ID=-100123...

# ── Owner identity (used for generated filenames) ─────────────────────────────
# Set to Firstname_LASTNAME (e.g. John_DOE) — used in CV/cover-letter filenames
CV_OWNER_SLUG=Firstname_LASTNAME

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Set to "true" to archive immediately without approval buttons
AUTO_APPLY=false
