# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit secrets.

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather
TELEGRAM_BOT_TOKEN=12345:ABC...

# The chat ID where the bot sends previews (your personal chat or a group)
# The channel ID where approved applications are archived (private channel)
TELEGRAM_CHAT_ID=-100123...

# ── Owner identity (used for generated filenames) ─────────────────────────────
# Set to Firstname_LASTNAME (e.g. John_DOE) — used in CV/cover-letter filenames
CV_OWNER_SLUG=Firstname_LASTNAME

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Set to "true" to archive immediately without approval buttons
AUTO_APPLY=false

# ── Personal-data vault (outside the repo) ────────────────────────────────────
# Personal data (CV profiles, master CVs, tracker DB, personal_data.tex) lives in
# a central vault OUTSIDE the repo, never committed. Resolution order:
#   APPLYFORGE_DATA_DIR  →  $XDG_DATA_HOME/agent-projects/applyforge  →
#   ~/.local/share/agent-projects/applyforge
# Uncomment to override the location:
# APPLYFORGE_DATA_DIR=/path/to/agent-projects/applyforge

# ── Output directories ────────────────────────────────────────────────────────
# Where generated CVs/cover letters are saved (defaults to Applied/ inside repo)
JOB_APPLY_DIR=/path/to/Job-Search/applied
PHD_APPLY_DIR=/path/to/PhD-Search/applied
